# Jetty Planning System - Backend
# Copy to .env and adjust. Used by dotenv when running `npm` locally.
# Backend/docker-compose.yml requires POSTGRES_PASSWORD and JWT_SECRET (no inline defaults).
#   docker compose --env-file .env up -d --build
# For Docker (jps-db + jps-api), pass this file explicitly (repo root):
#   docker compose --env-file Backend/.env -f docker-compose.backend.yml up -d
# Do not commit .env.

# API
PORT=3000
# Optional: max HTTP request header size in bytes (default 131072). Raise if ERR_CONNECTION_RESET on OIDC callback with huge Cookie headers.
# HTTP_MAX_HEADER_SIZE=131072
# OIDC redirect: on Windows Docker, if localhost:3000 resets but 127.0.0.1:3000 works, use http://127.0.0.1:3000/auth/oidc/callback here and in Hub.
NODE_ENV=development
# Comma-separated browser origins allowed to call the API (credentials + CORS).
# Local Vite: match dev server. Production Alicloud (private + public URL): list both, e.g.
#   CORS_ORIGIN=http://172.28.92.56:3080,http://203.0.113.10:3080
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# PostgreSQL (used by docker-compose for jps-db and DATABASE_URL for jps-api)
# docker-compose.backend.yml maps host 127.0.0.1:5436 -> container 5432 (optional; avoids clashing with host Postgres).
POSTGRES_USER=jps_user
POSTGRES_PASSWORD=jps_dev_password
POSTGRES_DB=jps_db

# Three-server layout (API on backend host, Postgres on dedicated DB host)
# Backend server after cutover: set DB_HOST to DB private IP (e.g. 172.28.92.60)
# DB_HOST=172.28.92.60
# DB_PORT=5432
# DB server only: bind Postgres to private IP (see Backend/infra/docker-compose.db.yml)
# DB_BIND_IP=172.28.92.60

# Auth (use a strong secret in production). Session cookie max-age follows JWT_EXPIRES_IN.
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=8h

# Browser SPA over http://localhost:5173 â€” set false or session cookies are rejected (401 on /users/me).
# COOKIE_SECURE=false
# Return JWT in login JSON for API clients only (browser SPA uses HttpOnly cookie).
# AUTH_RETURN_TOKEN_BODY=false
# Max login attempts per IP per window (see express-rate-limit in auth route).
# AUTH_LOGIN_MAX_ATTEMPTS=40
# Trust proxy hops for rate limiting / client IP (e.g. 1 behind one ALB).
# TRUST_PROXY=1

# IANA timezone for Jetty Operation Id (LD|UN-YY-MM-####) month bucket; must match migration 056 backfill literal (default Asia/Jakarta).
# Keep aligned with `ports.schedule_timezone` (migration 058) for each port’s business calendar.
# JETTY_OPERATION_CODE_TIMEZONE=Asia/Jakarta

# Downstream Hub SSO (POST /auth/hub). Must match Hub SSO_TOKEN_SECRET for this environment.
# SSO_TOKEN_SECRET=
# Redirect browser here after successful SSO (Vite dev or public SPA origin). Default http://localhost:5173
# JPS_PUBLIC_ORIGIN=http://127.0.0.1:5173
# Optional JIT: auto-create Jetty user when Hub email is unknown (requires HUB_SSO_JIT_ROLE_NAME).
# HUB_SSO_JIT_PROVISION=false
# HUB_SSO_JIT_ROLE_NAME=JPS Full Access
# HUB_SSO_JIT_ASSIGN_PORTS=first
# Strict OIDC SSO (Downstream Hub as provider)
# OIDC_ISSUER=http://172.28.92.56:3010
# OIDC_DISCOVERY_URL=http://172.28.92.56:3010/api/sso/.well-known/openid-configuration
# OIDC_CLIENT_ID=jetty-planning-system
# OIDC_REDIRECT_URI=http://127.0.0.1:3000/auth/oidc/callback
# OIDC_SCOPES=openid profile email
# OIDC_JIT_PROVISION=false
# SSO v2 silent linking (SSO-INTEGRATION-GUIDE §4): bind existing local user by verified email + optional domain allowlist.
# Default false preserves legacy 409 email_collision_local_account when sub is unknown.
# OIDC_V2_SILENT_LINK=false
# Comma-separated email domain suffixes, e.g. @company.com,other.com — empty = no domain restriction.
# OIDC_EMAIL_DOMAIN_ALLOWLIST=
# OIDC_ALLOW_QUERY_CODE_VERIFIER=false
# SSO_OIDC_ENABLED=false
# Keep true during migration; set false after strict OIDC cutover
# SSO_LEGACY_BRIDGE_ENABLED=true

# Central notifications — email outbox (optional). Without SMTP_HOST, deliveries are marked skipped.
# Admin UI can store SMTP in database (smtp_config); env vars are fallback when DB config is disabled.
# NOTIFICATION_ENCRYPTION_KEY=  # optional; defaults to JWT_SECRET for SMTP password encryption at rest
# APP_PUBLIC_URL=http://localhost:5173
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_PASSWORD=  # alias for SMTP_PASS
# SMTP_FROM=
# SMTP_REJECT_UNAUTHORIZED=true
# NOTIFICATION_EMAIL_POLL_MS=20000

# Uploaded files (operation docs, SI PDFs, berthing photos).
#
# Local npm dev: omit UPLOAD_DIR to use Backend/uploads.
# Local Docker: compose uses named volume jps_uploads at /var/jps/uploads (default).
# UPLOAD_DIR=/var/jps/uploads
#
# Staging / production (Synology NAS): set UPLOAD_HOST_PATH to the NAS folder mounted on
# the API host. Compose bind-mounts it into the container at /var/jps/uploads.
# Host mount root: /mnt/synology (File Station: 172.30.1.94/...)
#
# Staging (File Station: 172.30.1.94/dev/JETTYPLANNING):
# UPLOAD_HOST_PATH=/mnt/synology/dev/JETTYPLANNING
#
# Production (File Station: 172.30.1.94/JETTYPLANNING):
# UPLOAD_HOST_PATH=/mnt/synology/JETTYPLANNING
#
# See Docs/Plan/SYNOLOGY-INTEGRATION.md for cutover, migration, and verification.
