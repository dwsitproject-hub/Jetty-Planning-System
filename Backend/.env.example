# Jetty Planning System - Backend
# Copy to .env and adjust. Used by dotenv when running `npm` locally.
# For Docker (jps-db + jps-api), pass this file explicitly (repo root):
#   docker compose --env-file Backend/.env -f docker-compose.backend.yml up -d
# Do not commit .env.

# API
PORT=3000
NODE_ENV=development
# Comma-separated browser origins allowed to call the API (credentials + CORS).
# Local Vite: match dev server. Production Alicloud (private + public URL): list both, e.g.
#   CORS_ORIGIN=http://172.28.92.56:3080,http://203.0.113.10:3080
CORS_ORIGIN=http://localhost:5173

# PostgreSQL (used by docker-compose for jps-db and DATABASE_URL for jps-api)
# docker-compose.backend.yml maps host 127.0.0.1:5436 -> container 5432 (optional; avoids clashing with host Postgres).
POSTGRES_USER=jps_user
POSTGRES_PASSWORD=jps_dev_password
POSTGRES_DB=jps_db

# Auth (use a strong secret in production). Session cookie max-age follows JWT_EXPIRES_IN.
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=8h

# Browser SPA over http://localhost:5173 — set false or session cookies are rejected (401 on /users/me).
# COOKIE_SECURE=false
# Return JWT in login JSON for API clients only (browser SPA uses HttpOnly cookie).
# AUTH_RETURN_TOKEN_BODY=false
# Max login attempts per IP per window (see express-rate-limit in auth route).
# AUTH_LOGIN_MAX_ATTEMPTS=40
# Trust proxy hops for rate limiting / client IP (e.g. 1 behind one ALB).
# TRUST_PROXY=1

# Downstream Hub SSO (POST /auth/hub). Must match Hub SSO_TOKEN_SECRET for this environment.
# SSO_TOKEN_SECRET=
# Redirect browser here after successful SSO (Vite dev or public SPA origin). Default http://localhost:5173
# JPS_PUBLIC_ORIGIN=http://localhost:5173
# Optional JIT: auto-create Jetty user when Hub email is unknown (requires HUB_SSO_JIT_ROLE_NAME).
# HUB_SSO_JIT_PROVISION=false
# HUB_SSO_JIT_ROLE_NAME=JPS Full Access
# HUB_SSO_JIT_ASSIGN_PORTS=first
