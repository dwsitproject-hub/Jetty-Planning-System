# Jetty Planning System - Backend
# Copy to .env and adjust. Used by dotenv when running locally; docker-compose
# injects these (or overrides) when running in containers. Do not commit .env.

# API
PORT=3000
NODE_ENV=development
# Must match Vite dev server origin (repo root .env VITE_API_BASE_URL host is separate port 3000)
CORS_ORIGIN=http://localhost:5173

# PostgreSQL (used by docker-compose for jps-db and DATABASE_URL for jps-api)
# Host port is 5433 in docker-compose; use localhost:5433 in pgAdmin to avoid conflict with local Postgres on 5432.
POSTGRES_USER=jps_user
POSTGRES_PASSWORD=jps_dev_password
POSTGRES_DB=jps_db

# Auth (use a strong secret in production). Session cookie max-age follows JWT_EXPIRES_IN.
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRES_IN=8h
# Return JWT in login JSON for API clients only (browser SPA uses HttpOnly cookie).
# AUTH_RETURN_TOKEN_BODY=false
# Max login attempts per IP per window (see express-rate-limit in auth route).
# AUTH_LOGIN_MAX_ATTEMPTS=40
# Trust proxy hops for rate limiting / client IP (e.g. 1 behind one ALB).
# TRUST_PROXY=1
