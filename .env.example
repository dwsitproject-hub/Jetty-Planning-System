# Copy to .env in this folder (repo root — same level as vite.config.js)
# Backend API (Docker jps-api default: port 3000)
#
# Docker Compose (API + Postgres) reads vars from the file you pass with --env-file.
# To use Backend/.env for POSTGRES_PASSWORD, JWT_SECRET, CORS_ORIGIN, etc.:
#   docker compose --env-file Backend/.env -f docker-compose.backend.yml up -d
#
# Staging/production NAS uploads: set UPLOAD_HOST_PATH in Backend/.env (see Backend/.env.example
# and Docs/Plan/SYNOLOGY-INTEGRATION.md). Compose bind-mounts that host path into jps-api.
#
# Production (app Docker build): use relative base so private IP and public EIP both work:
#   VITE_API_BASE_URL=/api/v1
# Local Vite dev: keep full URL to the API:
VITE_API_BASE_URL=http://127.0.0.1:3000/api/v1
#
# Optional: show legacy plan-based Vessel Pipeline on Dashboard (Actuals pipeline is always on; frontend rebuild required).
# VITE_USE_LEGACY_VESSEL_PIPELINE=true
#
# Jetty Live (docker-compose.app.yml): copy rtsp-stream-viewer/.env.example → rtsp-stream-viewer/.env
# and set RTSP_URL (and RTSP_TRANSPORT=tcp). Deploy with:
#   docker compose -f docker-compose.app.yml up -d --build
