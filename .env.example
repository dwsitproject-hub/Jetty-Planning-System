# Copy to .env in this folder (repo root — same level as vite.config.js)
# Backend API (Docker jps-api default: port 3000)
#
# Docker Compose (API + Postgres) reads vars from the file you pass with --env-file.
# To use Backend/.env for POSTGRES_PASSWORD, JWT_SECRET, CORS_ORIGIN, etc.:
#   docker compose --env-file Backend/.env -f docker-compose.backend.yml up -d

VITE_API_BASE_URL=http://localhost:3000/api/v1
