# Production app server (see Docs/Guide/JETTY-LIVE-STREAM-DEPLOYMENT.md)
RTSP_URL=rtsp://USER:PASS@172.16.247.222:554/Stream1
RTSP_TRANSPORT=tcp
HTTP_PORT=3081
WS_PORT=9999
# Output frame rate for FFmpeg MPEG1 transcode (default 1; was hardcoded 25)
STREAM_OUTPUT_FPS=1
# Stop FFmpeg this many ms after the last WebSocket viewer disconnects (default 30000)
STREAM_IDLE_STOP_MS=30000
# STREAM_CORS_ORIGINS=http://<APP_PUBLIC_IP>:3080

# Optional: log FFmpeg stderr (debug RTSP on server)
# STREAM_LOG_FFMPEG=1
