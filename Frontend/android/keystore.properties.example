# Copy to `keystore.properties` (gitignored) next to this file, then create a keystore:
#   keytool -genkey -v -keystore jps-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias jps
# Point the paths/passwords below at it. Used by the release signingConfig in
# app/build.gradle (see Docs/Guide/MOBILE-BUILD.md §6). NEVER commit the real file or the .jks.
storeFile=../jps-release.jks
storePassword=CHANGE_ME
keyAlias=jps
keyPassword=CHANGE_ME
